generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id              String        @id @default(cuid())
  name            String?
  email           String        @unique
  emailVerified   DateTime?
  image           String?
  password        String?
  age             Int?
  gender          String?
  height          Float?
  weight          Float?
  goal            String?
  experienceLevel String?
  workoutTime     Int?
  role            Role          @default(USER)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  accounts        Account[]
  sessions        Session[]
  workouts        Workout[]
  dietPlans       DietPlan[]
  bmiHistory      BMIHistory[]
  calorieLogs     CalorieLog[]
  chatHistory     ChatHistory[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Workout {
  id             String   @id @default(cuid())
  userId         String
  date           DateTime @default(now())
  workoutType    String
  goal           String
  exercises      Json
  caloriesBurned Int
  completed      Boolean  @default(false)
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model DietPlan {
  id        String   @id @default(cuid())
  userId    String
  mealPlan  Json
  calories  Int
  protein   Int
  carbs     Int
  fats      Int
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model BMIHistory {
  id        String   @id @default(cuid())
  userId    String
  bmi       Float
  category  String
  height    Float
  weight    Float
  date      DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model CalorieLog {
  id        String   @id @default(cuid())
  userId    String
  food      String
  quantity  String
  calories  Int
  date      DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ChatHistory {
  id       String   @id @default(cuid())
  userId   String
  message  String   @db.Text
  response String   @db.Text
  date     DateTime @default(now())
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

enum Role {
  USER
  ADMIN
}
